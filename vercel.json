{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "create-react-app",
      "buildCommand": "npm run build"
    },
    "backend": {
      "root": "backend",
      "framework": "express",
      "entrypoint": "server.js"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/:path*",
      "destination": {
        "service": "frontend"
      }
    }
  ]
}
